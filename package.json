{
  "name": "go-hockey",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "local:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "local:laragon": "powershell -ExecutionPolicy Bypass -File scripts/setup-laragon.ps1",
    "local:xampp": "powershell -ExecutionPolicy Bypass -File scripts/setup-xampp.ps1",
    "local:install": "powershell -ExecutionPolicy Bypass -File scripts/local-install.ps1",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.0.0"
  }
}
